") + ")\\n" +
\par                                      "BodyPct:" + str.tostring(body_percent, "#.#") + "% (\u8805\'3d" + str.tostring(resistance_min_candle_body_percent, "#.#") + "%=" + (meets_body_requirement ? "\u10003\'3f" : "}{\rtlch\fcs1 \af45 \ltrch\fcs0 
\f45\insrsid78184 \u10007\'3f}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid78184 ") + ")\\n" +
\par                                      "Bearish:" + (is_bearish_candle ? "\u10003\'3f" : "}{\rtlch\fcs1 \af45 \ltrch\fcs0 \f45\insrsid78184 \u10007\'3f}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid78184 ") + " CloseBelow:" + (closes_below_resistance ? "}{
