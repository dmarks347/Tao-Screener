\par 
\par // Support Touch Strategy Inputs (Long positions)
\par min_separation_candles = input.int(1, "Minimum Separation Candles", minval=0, step=1, group="Support Strategy")
\par max_separation_candles = input.int(50, "Maximum Separation Candles", minval=1, step=1, group="Support Strategy")
\par entry_window_candles = input.int(3, "Entry Window Candles", minval=1, step=1, group="Support Strategy", tooltip="Number of candles after touch to look for entry signal")
\par max_simultaneous_long_trades = input.int(1, "Max Simultaneous Long Trades", minval=1, maxval=5, step=1, group="Support Strategy", tooltip="Maximum number of open long trades at same time")
\par prevent_reentry_bars = input.int(5, "Prevent Re-entry Bars", minval=1, maxval=20, step=1, group="Support Strategy", tooltip="Bars to wait after stop loss before allowing re-entry at same level")
\par take_profit_multiple_long = input.float(2.0, "Long Take Profit Multiple", minval=0.5, maxval=10.0, step=0.1, group="Support Strategy")
\par min_candle_body_percent = input.float(25.0, "Min Candle Body %", minval=5.0, maxval=80.0, step=1.0, group="Support Strategy", tooltip="Minimum candle body size as % of candle range (high-low)")
\par 
