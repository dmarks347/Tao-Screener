\par // =============================================================================
\par // FUNCTIONS
\par // =============================================================================
\par 
\par // Calculate body base (bottom of candle body)
\par get_body_base(index) =>
\par     math.min(open[index], close[index])
\par 
\par // Calculate body top (top of candle body)
\par get_body_top(index) =>
\par     math.max(open[index], close[index])
\par 
\par // Calculate candle body size
\par get_body_size(index) =>
\par     math.abs(close[index] - open[index])
\par 
\par // Calculate top wick size
\par get_top_wick_size(index) =>
\par     high[index] - get_body_top(index)
\par 
\par // Calculate bottom wick size
\par get_bottom_wick_size(index) =>
\par     body_base = get_body_base(index)
\par     low[index] - body_base
\par 
\par // Check if two levels are within sensitivity percentage
\par levels_within_sensitivity(level1, level2, sensitivity) =>
\par     math.abs((level2 - level1) / level1) * 100 <= sensitivity
\par 
\par // Validate support level - only check violations from current bar to level formation
\par validate_support_level(level, level_formation_bar) =>
\par     valid = true
\par     violation_count = 0
\par     max_violations = math.floor(level_formation_bar * 0.3) // Allow up to 30% violations (very permissive)
\par     
\par     // Only check if we have bars to validate
\par     if level_formation_bar > 0
\par         // Only check from current bar to where the level was formed
\par         for i = 0 to level_formation_bar - 1
\par             if close[i] < level
\par                 violation_count := violation_count + 1
\par                 if violation_count > max_violations
\par                     valid := false
\par                     break
\par     valid
\par 
\par // Validate resistance level - only check violations from current bar to level formation
\par validate_resistance_level(level, level_formation_bar) =>
\par     valid = true
\par     violation_count = 0
\par     max_violations = math.floor(level_formation_bar * 0.3) // Allow up to 30% violations (very permissive)
\par     
\par     // Only check if we have bars to validate
\par     if level_formation_bar > 0
\par         // Only check from current bar to where the level was formed
\par         for i = 0 to level_formation_bar - 1
\par             if close[i] > level
\par                 violation_count := violation_count + 1
\par                 if violation_count > max_violations
\par                     valid := false
\par                     break
\par     valid
\par 
\par // Check if candles between two qualifying candles violate the level
\par validate_candles_between_support(start_idx, end_idx, min_level) =>
\par     valid = true
\par     violation_count = 0
\par     total_candles = end_idx - start_idx - 1
\par     max_violations = math.max(1, math.floor(total_candles * 0.3)) // Allow 30% violations
\par     
\par     if end_idx > start_idx + 1 and start_idx >= 0 and end_idx >= 0  // Only check if there are candles between and indices are valid
\par         for i = start_idx + 1 to end_idx - 1
\par             if open[i] < min_level or close[i] < min_level
\par                 violation_count := violation_count + 1
\par                 if violation_count > max_violations
\par                     valid := false
\par                     break
\par     valid
\par 
\par validate_candles_between_resistance(start_idx, end_idx, max_level) =>
\par     valid = true
\par     violation_count = 0
\par     total_candles = end_idx - start_idx - 1
\par     max_violations = math.max(1, math.floor(total_candles * 0.3)) // Allow 30% violations
\par     
\par     if end_idx > start_idx + 1 and start_idx >= 0 and end_idx >= 0  // Only check if there are candles between and indices are valid
\par         for i = start_idx + 1 to end_idx - 1
\par             if open[i] > max_level or close[i] > max_level
\par                 violation_count := violation_count + 1
\par                 if violation_count > max_violations
\par                     valid := false
\par                     break
\par     valid
\par 
\par // Check if level already exists in array (use sensitivity-based tolerance)
\par level_exists(levels_array, new_level, tolerance_percent) =>
\par     exists = false
\par     if array.size(levels_array) > 0
\par         for i = 0 to array.size(levels_array) - 1
\par             existing_level = array.get(levels_array, i)
\par             if math.abs(new_level - existing_level) / existing_level * 100 < tolerance_percent
\par                 exists := true
\par                 break
\par     exists
\par 
\par // Find support levels
\par find_support_levels() =>
\par     found_levels = array.new<float>()
\par     found_bar_indices = array.new<int>()
\par     
\par     // Start from most recent bars and work backwards
\par     for i = 0 to n - x
\par         body_base_reference = get_body_base(i)
\par         qualifying_candles = array.new<int>()
\par         qualifying_levels = array.new<float>()
\par         
\par         // Add the reference candle
\par         array.push(qualifying_candles, i)
\par         array.push(qualifying_levels, body_base_reference)
\par         
\par         // Look for additional qualifying candles
\par         search_end = math.min(n - 1, i + math.max(z + 10, 20))
\par         for j = i + 1 to search_end
\par             body_base_candidate = get_body_base(j)
\par             
\par             // Check if this candle's body base is within sensitivity of reference
\par             if levels_within_sensitivity(body_base_reference, body_base_candidate, y)
\par                 array.push(qualifying_candles, j)
\par                 array.push(qualifying_levels, body_base_candidate)
\par                 
\par                 // Stop searching if we have enough candles
\par                 if array.size(qualifying_candles) >= x
\par                     break
\par         
\par         // If we have enough qualifying candles, create a support level
\par         if array.size(qualifying_candles) >= x
\par             // Get the minimum level from all qualifying candles
\par             min_level = array.get(qualifying_levels, 0)
\par             oldest_candle_idx = array.get(qualifying_candles, 0)
\par             
\par             for k = 1 to array.size(qualifying_levels) - 1
\par                 current_level = array.get(qualifying_levels, k)
\par                 current_idx = array.get(qualifying_candles, k)
\par                 if current_level < min_level
\par                     min_level := current_level
\par                 if current_idx > oldest_candle_idx
\par                     oldest_candle_idx := current_idx
\par             
\par             // Validate no closes below in lookback period
\par             if validate_support_level(min_level, i)
\par                 // Validate candles between don't violate level (check between first and last qualifying candles)
\par                 if validate_candles_between_support(i, oldest_candle_idx, min_level)
\par                     // Check if this level already exists
\par                     if not level_exists(found_levels, min_level, y)
\par                         if array.size(found_levels) < max_levels
\par                             array.push(found_levels, min_level)
\par                             // Store bar index of the oldest qualifying candle
\par                             array.push(found_bar_indices, bar_index - oldest_candle_idx)
\par     
\par     [found_levels, found_bar_indices]
\par 
\par // Find resistance levels  
\par find_resistance_levels() =>
\par     found_levels = array.new<float>()
\par     found_bar_indices = array.new<int>()
\par     
\par     // Start from most recent bars and work backwards
\par     for i = 0 to n - x
\par         body_top_reference = get_body_top(i)
\par         qualifying_candles = array.new<int>()
\par         qualifying_levels = array.new<float>()
\par         
\par         // Add the reference candle
\par         array.push(qualifying_candles, i)
\par         array.push(qualifying_levels, body_top_reference)
\par         
\par         // Look for additional qualifying candles
\par         search_end = math.min(n - 1, i + math.max(z + 10, 20))
\par         for j = i + 1 to search_end
\par             body_top_candidate = get_body_top(j)
\par             
\par             // Check if this candle's body top is within sensitivity of reference
\par             if levels_within_sensitivity(body_top_reference, body_top_candidate, y)
\par                 array.push(qualifying_candles, j)
\par                 array.push(qualifying_levels, body_top_candidate)
\par                 
\par                 // Stop searching if we have enough candles
\par                 if array.size(qualifying_candles) >= x
\par                     break
\par         
\par         // If we have enough qualifying candles, create a resistance level
\par         if array.size(qualifying_candles) >= x
\par             // Get the maximum level from all qualifying candles
\par             max_level = array.get(qualifying_levels, 0)
\par             oldest_candle_idx = array.get(qualifying_candles, 0)
\par             
\par             for k = 1 to array.size(qualifying_levels) - 1
\par                 current_level = array.get(qualifying_levels, k)
\par                 current_idx = array.get(qualifying_candles, k)
\par                 if current_level > max_level
\par                     max_level := current_level
\par                 if current_idx > oldest_candle_idx
\par                     oldest_candle_idx := current_idx
\par             
\par             // Validate no closes above in lookback period
\par             if validate_resistance_level(max_level, i)
\par                 // Validate candles between don't violate level (check between first and last qualifying candles)
\par                 if validate_candles_between_resistance(i, oldest_candle_idx, max_level)
\par                     // Check if this level already exists
\par                     if not level_exists(found_levels, max_level, y)
\par                         if array.size(found_levels) < max_levels
\par                             array.push(found_levels, max_level)
\par                             // Store bar index of the oldest qualifying candle
\par                             array.push(found_bar_indices, bar_index - oldest_candle_idx)
\par     
\par     [found_levels, found_bar_indices]
\par 
\par // Clear existing lines
\par clear_lines(lines_array) =>
\par     if array.size(lines_array) > 0
\par         for i = 0 to array.size(lines_array) - 1
\par             line.delete(array.get(lines_array, i))
\par     array.clear(lines_array)
\par 
\par // Draw support and resistance lines
\par draw_levels() =>
\par     // Clear existing lines every 5 bars to refresh with most recent levels
\par     if bar_index % 5 == 0
\par         clear_lines(support_lines)
\par         clear_lines(resistance_lines)
\par         array.clear(support_levels)
\par         array.clear(resistance_levels)
\par         // Clear strategy tracking arrays
\par         array.clear(support_formation_bars)
\par         array.clear(support_used)
\par         array.clear(support_touched_bars)
\par         array.clear(support_pending_entry)
\par         // Clear resistance tracking arrays
\par         array.clear(resistance_formation_bars)
\par         array.clear(resistance_used)
\par         array.clear(resistance_touched_bars)
\par         array.clear(resistance_pending_entry)
\par     
\par     // Find new levels
\par     [current_support_levels, support_bar_indices] = find_support_levels()
\par     [current_resistance_levels, resistance_bar_indices] = find_resistance_levels()
\par     
\par     // Add new support lines (white) - only if they don't already exist and under max limit
\par     support_size = array.size(current_support_levels)
\par     support_indices_size = array.size(support_bar_indices)
\par     
\par     if support_size > 0 and support_indices_size > 0 and array.size(support_levels) < max_levels
\par         loop_count = math.min(support_size, support_indices_size)
\par         for i = 0 to loop_count - 1
\par             if array.size(support_levels) >= max_levels
\par                 break
\par                 
\par             level = array.get(current_support_levels, i)
\par             start_bar = array.get(support_bar_indices, i)
\par             
\par             // Check if this level already exists in our persistent array
\par             if not level_exists(support_levels, level, y)
\par                 support_line = line.new(start_bar, level, start_bar + 50, level, color=color.white, width=2, style=line.style_solid, extend=extend.right)
\par                 array.push(support_lines, support_line)
\par                 array.push(support_levels, level)
\par                 // Track formation data for strategy
\par                 array.push(support_formation_bars, start_bar)
\par                 array.push(support_used, false)
\par                 array.push(support_touched_bars, -1)
\par                 array.push(support_pending_entry, false)
\par     
\par     // Add new resistance lines (yellow) - only if they don't already exist and under max limit
\par     resistance_size = array.size(current_resistance_levels)
\par     resistance_indices_size = array.size(resistance_bar_indices)
\par     
\par     if resistance_size > 0 and resistance_indices_size > 0 and array.size(resistance_levels) < max_levels
\par         loop_count_r = math.min(resistance_size, resistance_indices_size)
\par         for i = 0 to loop_count_r - 1
\par             if array.size(resistance_levels) >= max_levels
\par                 break
\par                 
\par             level = array.get(current_resistance_levels, i)
\par             start_bar = array.get(resistance_bar_indices, i)
\par             
\par             // Check if this level already exists in our persistent array
\par             if not level_exists(resistance_levels, level, y)
\par                 resistance_line = line.new(start_bar, level, start_bar + 50, level, color=color.yellow, width=2, style=line.style_solid, extend=extend.right)
\par                 array.push(resistance_lines, resistance_line)
\par                 array.push(resistance_levels, level)
\par                 // Track formation data for strategy
\par                 array.push(resistance_formation_bars, start_bar)
\par                 array.push(resistance_used, false)
\par                 array.push(resistance_touched_bars, -1)
\par                 array.push(resistance_pending_entry, false)
\par 
\par // =============================================================================
\par // TRADE MANAGEMENT FUNCTIONS
\par // =============================================================================
\par 
\par // Count current open trades by direction
\par count_open_long_trades() =>
\par     math.max(0, strategy.position_size)
\par 
\par count_open_short_trades() =>
\par     math.max(0, -strategy.position_size)
\par 
\par count_total_open_trades() =>
\par     math.abs(strategy.position_size)
\par 
\par // Check if direction is allowed for new trades
\par can_trade_direction(direction) =>
\par     allowed = false
\par     if trade_direction == "Long Only"
\par         allowed := direction == "long"
\par     else if trade_direction == "Short Only"
\par         allowed := direction == "short"
\par     else if trade_direction == "Both"
\par         if not direction_blocked
\par             allowed := true
\par         else
\par             // Only allow same direction as current open trades
\par             allowed := direction == current_direction
\par     allowed
\par 
\par // Check if support level had recent stop loss
\par had_recent_support_stop_loss(level, tolerance_percent = 0.1) =>
\par     recent_stop = false
\par     if array.size(recent_support_stop_levels) > 0
\par         for i = 0 to array.size(recent_support_stop_levels) - 1
\par             if i < array.size(recent_support_stop_bars)
\par                 stop_level = array.get(recent_support_stop_levels, i)
\par                 stop_bar = array.get(recent_support_stop_bars, i)
\par                 bars_since_stop = bar_index - stop_bar
\par                 
\par                 // Check if current level is close to recent stop level and within prevention window
\par                 level_diff_percent = math.abs(level - stop_level) / stop_level * 100
\par                 if level_diff_percent <= tolerance_percent and bars_since_stop <= prevent_reentry_bars
\par                     recent_stop := true
\par                     break
\par     recent_stop
\par 
\par // Check if resistance level had recent stop loss
\par had_recent_resistance_stop_loss(level, tolerance_percent = 0.1) =>
\par     recent_stop = false
\par     if array.size(recent_resistance_stop_levels) > 0
\par         for i = 0 to array.size(recent_resistance_stop_levels) - 1
\par             if i < array.size(recent_resistance_stop_bars)
\par                 stop_level = array.get(recent_resistance_stop_levels, i)
\par                 stop_bar = array.get(recent_resistance_stop_bars, i)
\par                 bars_since_stop = bar_index - stop_bar
\par                 
\par                 // Check if current level is close to recent stop level and within prevention window
\par                 level_diff_percent = math.abs(level - stop_level) / stop_level * 100
\par                 if level_diff_percent <= tolerance_percent and bars_since_stop <= resistance_prevent_reentry_bars
\par                     recent_stop := true
\par                     break
\par     recent_stop
\par 
\par // =============================================================================
\par // SUPPORT STRATEGY FUNCTIONS
\par // =============================================================================
\par 
\par // Check if candle touches support level AND closes above it
\par touches_support_level(index, support_level) =>
\par     low[index] <= support_level and close[index] > support_level
\par 
\par // Check separation candles between support formation and current candle
\par check_separation_candles(support_formation_bar, support_level) =>
\par     // Calculate number of candles between formation and current candle
\par     bars_since_formation = bar_index - support_formation_bar
\par     candles_between = bars_since_formation - 1
\par     
\par     // Only check if we have the required minimum separation candles
\par     // Remove the restriction about not touching support - separation candles can touch/wick through support
\par     candles_between >= min_separation_candles and candles_between <= max_separation_candles
\par 
\par // Track support touches (call this every bar)
\par track_support_touches() =>
\par     if array.size(support_levels) > 0
\par         for i = 0 to array.size(support_levels) - 1
\par             // Ensure arrays exist and have this index
\par             if i < array.size(support_formation_bars) and i < array.size(support_used) and 
\par                i < array.size(support_touched_bars) and i < array.size(support_pending_entry)
\par                 
\par                 support_level = array.get(support_levels, i)
\par                 formation_bar = array.get(support_formation_bars, i)
\par                 already_used = array.get(support_used, i)
\par                 
\par                 // Check if current candle touches support and hasn't been used
\par                 if not already_used and touches_support_level(0, support_level)
\par                     // Check separation candles
\par                     separation_valid = check_separation_candles(formation_bar, support_level)
\par                     
\par                     if separation_valid
\par                         // Only mark as touched if not already pending entry (first touch only)
\par                         current_pending_entry = array.get(support_pending_entry, i)
\par                         if not current_pending_entry
\par                             // Mark this support as touched and pending entry evaluation
\par                             array.set(support_touched_bars, i, bar_index)
\par                             array.set(support_pending_entry, i, true)
\par                             
\par                             // Add debug label for successful touch
\par                             label.new(bar_index + 2, low[0], 
\par                                       "TOUCH OK: " + str.tostring(support_level, "#.##") + " i:" + str.tostring(i), 
\par                                       color=color.blue, textcolor=color.white, size=size.small, style=label.style_label_up)
\par 
\par // Check for support entry opportunities (evaluate candles after touches)
\par check_support_entry() =>
\par     entry_found = false
\par     entry_support_level = 0.0
\par     entry_support_index = -1
\par     
\par     if array.size(support_levels) > 0 and array.size(support_touched_bars) > 0 and array.size(support_pending_entry) > 0
\par         for i = 0 to array.size(support_levels) - 1
\par             // Ensure all arrays have this index
\par             if i < array.size(support_formation_bars) and i < array.size(support_used) and i < array.size(support_touched_bars) and i < array.size(support_pending_entry)
\par                 support_level = array.get(support_levels, i)
\par                 formation_bar = array.get(support_formation_bars, i)
\par                 already_used = array.get(support_used, i)
\par                 touched_bar = array.get(support_touched_bars, i)
\par                 pending_entry = array.get(support_pending_entry, i)
\par                 
\par                 // Check if support was touched within the entry window and is pending entry evaluation
\par                 if not already_used and pending_entry and touched_bar >= 0
\par                     bars_since_touch = bar_index - touched_bar
\par                     
\par                     // Check if we're within the entry window
\par                     if bars_since_touch >= 1 and bars_since_touch <= entry_window_candles
\par                         current_close = close[0]
\par                         current_open = open[0]
\par                         closes_above_support = current_close > support_level
\par                         
\par                         // CRITICAL: Entry candle must be bullish to confirm support bounce
\par                         is_bullish_candle = current_close > current_open
\par                         
\par                         body_size = get_body_size(0)
\par                         top_wick = get_top_wick_size(0)
\par                         wick_ratio = body_size > 0 ? (top_wick / body_size) : 0
\par                         wick_valid = wick_ratio <= 0.50
\par                         
\par                         // Check body size requirement - Use candle range instead of close price
\par                         candle_range = high[0] - low[0]
\par                         body_percent = candle_range > 0 ? (body_size / candle_range) * 100 : 0
\par                         meets_body_requirement = body_percent >= min_candle_body_percent
\par                         
\par                         all_conditions_met = closes_above_support and is_bullish_candle and wick_valid and meets_body_requirement
\par                         
\par                         // DEBUG: Add detailed validation label for long entries
\par                         debug_text = "LONG EVAL (Bar " + str.tostring(bars_since_touch) + "/" + str.tostring(entry_window_candles) + "):\\n" +
\par                                      "H:" + str.tostring(high[0], "#.##") + " O:" + str.tostring(open[0], "#.##") + "\\n" +
\par                                      "L:" + str.tostring(low[0], "#.##") + " C:" + str.tostring(close[0], "#.##") + "\\n" +
\par                                      "Body:" + str.tostring(body_size, "#.##") + " TopWick:" + str.tostring(top_wick, "#.##") + "\\n" +
\par                                      "WickRatio:" + str.tostring(wick_ratio, "#.##") + " (\u8804\'3d0.5=" + (wick_valid ? "\u10003\'3f" : "}{\rtlch\fcs1 \af45 \ltrch\fcs0 \f45\insrsid78184 \u10007\'3f}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid78184 
") + ")\\n" +
\par                                      "BodyPct:" + str.tostring(body_percent, "#.#") + "% (\u8805\'3d" + str.tostring(min_candle_body_percent, "#.#") + "%=" + (meets_body_requirement ? "\u10003\'3f" : "}{\rtlch\fcs1 \af45 \ltrch\fcs0 \f45\insrsid78184 
\u10007\'3f}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid78184 ") + ")\\n" +
\par                                      "Bullish:" + (is_bullish_candle ? "\u10003\'3f" : "}{\rtlch\fcs1 \af45 \ltrch\fcs0 \f45\insrsid78184 \u10007\'3f}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid78184 ") + " CloseAbove:" + (closes_above_support ? "}{
\rtlch\fcs1 \af43 \ltrch\fcs0 \f43\insrsid78184 \u10003\'3f}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid78184 " : "}{\rtlch\fcs1 \af45 \ltrch\fcs0 \f45\insrsid78184 \u10007\'3f}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid78184 ") + "\\n" +
\par                                      "AllMet:" + (all_conditions_met ? "\u10003\'3f ENTRY!" : "}{\rtlch\fcs1 \af45 \ltrch\fcs0 \f45\insrsid78184 \u10007\'3f}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid78184 ")
\par                         
\par                         label.new(bar_index - 1, low[0] - (high[0] - low[0]) * 0.1, debug_text, 
\par                                   color=all_conditions_met ? color.lime : color.orange, textcolor=color.black, 
\par                                   size=size.small, style=label.style_label_up, xloc=xloc.bar_index)
\par                         
\par                         if all_conditions_met
\par                             entry_found := true
\par                             entry_support_level := support_level
\par                             entry_support_index := i
\par                             // Clear the pending entry flag since we're taking the trade
\par                             array.set(support_pending_entry, i, false)
\par                             break
\par                         
\par                     else if bars_since_touch > entry_window_candles
\par                         // Entry window has expired, clear the pending entry flag
\par                         array.set(support_pending_entry, i, false)
\par     
\par     [entry_found, entry_support_level, entry_support_index]
\par 
\par // =============================================================================
\par // RESISTANCE STRATEGY FUNCTIONS
\par // =============================================================================
\par 
\par // Check if candle touches resistance level with upward price action (for resistance test)
\par touches_resistance_level(index, resistance_level) =>
\par     high[index] >= resistance_level and close[index] >= resistance_level
\par 
\par // Check separation candles between resistance formation and current candle
