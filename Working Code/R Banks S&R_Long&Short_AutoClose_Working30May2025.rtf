\par                         // Entry window has expired, clear the pending entry flag
\par                         array.set(resistance_pending_entry, i, false)
\par     
\par     [entry_found, entry_resistance_level, entry_resistance_index]
\par 
\par // =============================================================================
\par // TIME FUNCTIONS
\par // =============================================================================
\par 
\par // Convert time string to minutes since midnight
\par time_to_minutes(time_str) =>
\par     hour_str = str.substring(time_str, 0, 2)
\par     minute_str = str.substring(time_str, 3, 5)
\par     hour_val = str.tonumber(hour_str)
\par     minute_val = str.tonumber(minute_str)
\par     hour_val * 60 + minute_val
\par 
\par // Check if current time is within specified range (New York time)
\par is_in_time_range(start_time_str, end_time_str) =>
\par     // Get current bar's time and convert to New York timezone
\par     current_hour = hour(time, "America/New_York")
\par     current_minute = minute(time, "America/New_York")
\par     current_minutes = current_hour * 60 + current_minute
\par     
\par     start_minutes = time_to_minutes(start_time_str)
\par     end_minutes = time_to_minutes(end_time_str)
\par     
\par     if start_minutes <= end_minutes
\par         // Same day range
\par         current_minutes >= start_minutes and current_minutes <= end_minutes
\par     else
\par         // Overnight range (crosses midnight)
\par         current_minutes >= start_minutes or current_minutes <= end_minutes
\par 
\par // Check if we should detect S/R levels
\par is_sr_detection_time = is_in_time_range(sr_start_time, sr_end_time)
\par 
\par // Check if it's time to close all trades and stop new entries
\par is_closeout_time = is_in_time_range(daily_closeout_time, "23:59")
\par 
\par // Check if we can execute long and short trades separately (but not after close-out time)
\par is_long_trading_time = is_in_time_range(long_trade_start_time, long_trade_end_time) and not is_closeout_time
\par is_short_trading_time = is_in_time_range(short_trade_start_time, short_trade_end_time) and not is_closeout_time
\par 
\par // =============================================================================
\par // MAIN EXECUTION
\par // =============================================================================
\par 
\par // Only process on confirmed bars to avoid repainting
\par if barstate.isconfirmed
\par     // Update trade counts in global scope (cannot modify global vars in functions)
\par     long_trades_count := math.round(count_open_long_trades())
\par     short_trades_count := math.round(count_open_short_trades())
\par     
\par     // Direction blocking logic in global scope
\par     if long_trades_count > 0 and short_trades_count == 0
\par         current_direction := "long"
\par         direction_blocked := true
\par     else if short_trades_count > 0 and long_trades_count == 0
\par         current_direction := "short"
\par         direction_blocked := true
\par     else if long_trades_count == 0 and short_trades_count == 0
\par         current_direction := na
\par         direction_blocked := false
\par     // If somehow both are open (shouldn't happen), block everything
\par     else if long_trades_count > 0 and short_trades_count > 0
\par         direction_blocked := true
\par     
\par     // Daily close-out: Close all trades at specified time
\par     if is_closeout_time and (strategy.position_size != 0)
\par         strategy.close_all("Daily Close-Out")
\par         
\par         // Add debug label for close-out
\par         label.new(bar_index, close[0], "DAILY CLOSE-OUT\\nAll trades closed", 
\par                   color=color.purple, textcolor=color.white, size=size.normal, style=label.style_label_center)
\par     
\par     // Only detect S/R levels during specified hours
\par     if is_sr_detection_time
\par         draw_levels()
\par     
\par     // Track touches every bar during trading hours
\par     if is_long_trading_time
\par         track_support_touches()
\par         track_resistance_touches()
\par     
\par     // Check for entry signals (only during trading hours)
\par     if is_long_trading_time
\par         // Check for long entry signals
\par         if not long_entry_signaled and can_trade_direction("long")
\par             [long_entry_found, support_level, support_index] = check_support_entry()
\par             
\par             if long_entry_found
\par                 // Check if we can open a new long trade
\par                 current_long_trades = count_open_long_trades()
\par                 can_open_trade = current_long_trades < max_simultaneous_long_trades
\par                 
\par                 // Check if this level had a recent stop loss
\par                 recent_stop_at_level = had_recent_support_stop_loss(support_level)
\par                 
\par                 if can_open_trade and not recent_stop_at_level
\par                     long_entry_signaled := true
\par                     long_entry_price := close[0]
\par                     used_support_index := support_index
\par                     long_trade_counter := long_trade_counter + 1
\par                     
\par                     // Mark this support level as used
\par                     array.set(support_used, support_index, true)
\par                     
\par                     // Calculate stop loss (low of previous candle)
\par                     long_stop_loss := low[1]
\par                     
\par                     // Calculate take profit
\par                     risk = long_entry_price - long_stop_loss
\par                     long_take_profit := long_entry_price + (risk * take_profit_multiple_long)
\par                     
\par                     // Add debug label for entry signal
\par                     label.new(bar_index, close[0], "LONG ENTRY SIGNAL #" + str.tostring(long_trade_counter), 
\par                               color=color.lime, textcolor=color.black, size=size.normal)
\par         
\par     if is_short_trading_time
\par         // Track resistance touches during short trading hours
\par         track_resistance_touches()
\par         
\par         // Check for short entry signals
\par         if not short_entry_signaled and can_trade_direction("short")
\par             [short_entry_found, resistance_level, resistance_index] = check_resistance_entry()
\par             
\par             if short_entry_found
\par                 // Check if we can open a new short trade
\par                 current_short_trades = count_open_short_trades()
\par                 can_open_trade = current_short_trades < max_simultaneous_short_trades
\par                 
\par                 // Check if this level had a recent stop loss
\par                 recent_stop_at_level = had_recent_resistance_stop_loss(resistance_level)
\par                 
\par                 if can_open_trade and not recent_stop_at_level
\par                     short_entry_signaled := true
\par                     short_entry_price := close[0]
\par                     used_resistance_index := resistance_index
\par                     short_trade_counter := short_trade_counter + 1
\par                     
\par                     // Mark this resistance level as used
\par                     array.set(resistance_used, resistance_index, true)
\par                     
\par                     // Calculate stop loss (high of previous candle)
\par                     short_stop_loss := high[1]
\par                     
\par                     // Calculate take profit
\par                     risk = short_stop_loss - short_entry_price
\par                     short_take_profit := short_entry_price - (risk * take_profit_multiple_short)
\par                     
\par                     // Add debug label for entry signal
\par                     label.new(bar_index, close[0], "SHORT ENTRY SIGNAL #" + str.tostring(short_trade_counter), 
\par                               color=color.red, textcolor=color.white, size=size.normal)
\par 
\par // Execute long trades on new bar if entry was signaled
\par if barstate.isconfirmed and long_entry_signaled and is_long_trading_time
\par     // Create unique trade ID
\par     long_trade_id = "Long_" + str.tostring(long_trade_counter)
\par     
\par     strategy.entry(long_trade_id, strategy.long)
\par     strategy.exit("LongExit_" + str.tostring(long_trade_counter), long_trade_id, stop=long_stop_loss, limit=long_take_profit)
\par     
\par     // Add debug label for actual trade entry
\par     label.new(bar_index, close[0], "LONG ENTERED #" + str.tostring(long_trade_counter), 
\par               color=color.yellow, textcolor=color.black, size=size.normal)
\par     
\par     // Reset signals
\par     long_entry_signaled := false
\par 
\par // Execute short trades on new bar if entry was signaled
\par if barstate.isconfirmed and short_entry_signaled and is_short_trading_time
\par     // Create unique trade ID
\par     short_trade_id = "Short_" + str.tostring(short_trade_counter)
\par     
\par     strategy.entry(short_trade_id, strategy.short)
\par     strategy.exit("ShortExit_" + str.tostring(short_trade_counter), short_trade_id, stop=short_stop_loss, limit=short_take_profit)
\par     
\par     // Add debug label for actual trade entry
\par     label.new(bar_index, close[0], "SHORT ENTERED #" + str.tostring(short_trade_counter), 
\par               color=color.purple, textcolor=color.white, size=size.normal)
\par     
\par     // Reset signals
\par     short_entry_signaled := false
\par 
\par // Track when long stop losses occur
\par if strategy.position_size[1] > 0 and strategy.position_size == 0
\par     // Long position was just closed - likely a stop loss
\par     if not na(long_stop_loss)
\par         array.push(recent_support_stop_levels, long_stop_loss)
\par         array.push(recent_support_stop_bars, bar_index)
\par         
\par         // Keep only recent stop losses (last 20)
\par         if array.size(recent_support_stop_levels) > 20
\par             array.shift(recent_support_stop_levels)
\par             array.shift(recent_support_stop_bars)
\par 
\par // Track when short stop losses occur
\par if strategy.position_size[1] < 0 and strategy.position_size == 0
\par     // Short position was just closed - likely a stop loss
\par     if not na(short_stop_loss)
\par         array.push(recent_resistance_stop_levels, short_stop_loss)
\par         array.push(recent_resistance_stop_bars, bar_index)
\par         
\par         // Keep only recent stop losses (last 20)
\par         if array.size(recent_resistance_stop_levels) > 20
\par             array.shift(recent_resistance_stop_levels)
\par             array.shift(recent_resistance_stop_bars)
\par 
\par // =============================================================================
\par // PLOTTING AND LABELS
\par // =============================================================================
\par 
\par // Mark support and resistance touches
\par support_touch_found = false
\par resistance_touch_found = false
\par 
\par if array.size(support_levels) > 0 and array.size(support_touched_bars) > 0 and is_long_trading_time
\par     for i = 0 to array.size(support_levels) - 1
\par         if i < array.size(support_touched_bars)
\par             touched_bar = array.get(support_touched_bars, i)
\par             if touched_bar == bar_index
\par                 support_touch_found := true
\par                 break
\par 
\par if array.size(resistance_levels) > 0 and array.size(resistance_touched_bars) > 0 and is_short_trading_time
\par     for i = 0 to array.size(resistance_levels) - 1
\par         if i < array.size(resistance_touched_bars)
