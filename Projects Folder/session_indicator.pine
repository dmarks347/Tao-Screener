//@version=5
indicator("Session High/Low Lines (Asia, London, NY) - Multi Session", overlay=true, max_lines_count=54, max_labels_count=6)

// === INPUTS ===
showAsia   = input.bool(true, "Show Asia Session")
asiaStartH = input.int(23, "Asia Start Hour (GMT)", minval=0, maxval=23, group="Asia")
asiaStartM = input.int(0, "Asia Start Minute (GMT)", minval=0, maxval=59, group="Asia")
asiaEndH   = input.int(7, "Asia End Hour (GMT)", minval=0, maxval=23, group="Asia")
asiaEndM   = input.int(0, "Asia End Minute (GMT)", minval=0, maxval=59, group="Asia")
asiaColor  = input.color(color.blue, "Asia Session Color", group="Asia")

showLondon = input.bool(true, "Show London Session")
londonStartH = input.int(7, "London Start Hour (GMT)", minval=0, maxval=23, group="London")
londonStartM = input.int(0, "London Start Minute (GMT)", minval=0, maxval=59, group="London")
londonEndH   = input.int(15, "London End Hour (GMT)", minval=0, maxval=23, group="London")
londonEndM   = input.int(0, "London End Minute (GMT)", minval=0, maxval=59, group="London")
londonColor  = input.color(color.yellow, "London Session Color", group="London")

showNY     = input.bool(true, "Show NY Session")
nyStartH   = input.int(13, "NY Start Hour (GMT)", minval=0, maxval=23, group="NY")
nyStartM   = input.int(0, "NY Start Minute (GMT)", minval=0, maxval=59, group="NY")
nyEndH     = input.int(21, "NY End Hour (GMT)", minval=0, maxval=23, group="NY")
nyEndM     = input.int(0, "NY End Minute (GMT)", minval=0, maxval=59, group="NY")
nyColor    = input.color(color.lime, "NY Session Color", group="NY")

useDST     = input.bool(false, "Add 1 hour for DST?", group="General")
sessionsToShow = input.int(3, "Number of Sessions to Show", minval=1, maxval=10, group="General")

// === SESSION TIME CALCULATION ===
getSessionTimes(starth, startm, endh, endm) =>
    _dst = useDST ? 1 : 0
    start = starth + _dst
    end   = endh + _dst
    [start, startm, end, endm]

// Returns true if the current bar is in the session (GMT)
inSession(starth, startm, endh, endm) =>
    sessStart = starth * 60 + startm
    sessEnd   = endh * 60 + endm
    t = hour * 60 + minute
    sessStart < sessEnd ? (t >= sessStart and t < sessEnd) : (t >= sessStart or t < sessEnd)

// === SESSION DRAW FUNCTION ===
drawSessionLines(startBars, endBars, highs, lows, highBroken, lowBroken, highBreakBar, lowBreakBar, color_, name_) =>
    sz = array.size(startBars)
    for i = 0 to sz - 1
        if array.size(startBars) > i and array.size(endBars) > i and array.size(highs) > i and array.size(lows) > i and array.size(highBroken) > i and array.size(lowBroken) > i and array.size(highBreakBar) > i and array.size(lowBreakBar) > i
            startBar = int(array.get(startBars, i))
            hi       = array.get(highs, i)
            lo       = array.get(lows, i)
            isHighBroken = array.get(highBroken, i)
            isLowBroken = array.get(lowBroken, i)
            highBreak = int(array.get(highBreakBar, i))
            lowBreak = int(array.get(lowBreakBar, i))
            
            if not na(startBar) and not na(hi) and not na(lo)
                // Draw high line
                highEndBar = isHighBroken ? highBreak : bar_index
                if highEndBar > startBar
                    line.new(startBar, hi, highEndBar, hi, color=color_, width=2)
                    // Add label only for the most recent session (i == 0)
                    if i == 0
                        highMidBar = startBar + math.round((highEndBar - startBar) * 0.5)
                        label.new(highMidBar, hi, name_, 
                                  color=color.new(color_, 100), 
                                  style=label.style_label_down, 
                                  textcolor=color_, 
                                  yloc=yloc.price)
                
                // Draw low line
                lowEndBar = isLowBroken ? lowBreak : bar_index
                if lowEndBar > startBar
                    line.new(startBar, lo, lowEndBar, lo, color=color_, width=2)
                    // Add label only for the most recent session (i == 0)
                    if i == 0
                        lowMidBar = startBar + math.round((lowEndBar - startBar) * 0.5)
                        label.new(lowMidBar, lo, name_, 
                                  color=color.new(color_, 100), 
                                  style=label.style_label_up, 
                                  textcolor=color_, 
                                  yloc=yloc.price)

// === SESSION LOGIC ===
processSession(show, starth, startm, endh, endm, color_, name_, startBars, endBars, highs, lows, highBroken, lowBroken, highBreakBar, lowBreakBar) =>
    var float hi = na
    var float lo = na
    var int startBar = na
    var int endBar = na
    [sH, sM, eH, eM] = getSessionTimes(starth, startm, endh, endm)
    inSess = inSession(sH, sM, eH, eM)
    newSession = na(inSess[1]) ? false : (not inSess[1] and inSess)
    
    if newSession
        hi := high
        lo := low
        startBar := bar_index
    if inSess
        hi := na(hi) ? high : math.max(hi, high)
        lo := na(lo) ? low : math.min(lo, low)
        endBar := bar_index
    
    endSession = na(inSess[1]) ? false : (inSess[1] and not inSess)
    if endSession and not na(hi) and not na(lo) and not na(startBar)
        array.unshift(startBars, float(startBar))
        array.unshift(endBars, float(endBar))
        array.unshift(highs, hi)
        array.unshift(lows, lo)
        array.unshift(highBroken, false)
        array.unshift(lowBroken, false)
        array.unshift(highBreakBar, float(bar_index))
        array.unshift(lowBreakBar, float(bar_index))
        // Limit to X sessions
        if array.size(startBars) > sessionsToShow
            array.pop(startBars)
            array.pop(endBars)
            array.pop(highs)
            array.pop(lows)
            array.pop(highBroken)
            array.pop(lowBroken)
            array.pop(highBreakBar)
            array.pop(lowBreakBar)
        hi := na
        lo := na
        startBar := na
        endBar := na
    
    // Check for breaks in existing lines
    if array.size(highs) > 0 and array.size(lows) > 0 and array.size(highBroken) > 0 and array.size(lowBroken) > 0
        for i = 0 to array.size(highs) - 1
            if close > array.get(highs, i) and not array.get(highBroken, i)
                array.set(highBroken, i, true)
                array.set(highBreakBar, i, float(bar_index))
            if close < array.get(lows, i) and not array.get(lowBroken, i)
                array.set(lowBroken, i, true)
                array.set(lowBreakBar, i, float(bar_index))

// --- Asia Session ---
var asiaStartBars = array.new_float()
var asiaEndBars   = array.new_float()
var asiaHighs     = array.new_float()
var asiaLows      = array.new_float()
var asiaHighBroken = array.new_bool()
var asiaLowBroken = array.new_bool()
var asiaHighBreakBar = array.new_float()
var asiaLowBreakBar = array.new_float()
if showAsia
    processSession(showAsia, asiaStartH, asiaStartM, asiaEndH, asiaEndM, asiaColor, "Asia", 
                  asiaStartBars, asiaEndBars, asiaHighs, asiaLows, asiaHighBroken, asiaLowBroken, asiaHighBreakBar, asiaLowBreakBar)
    if array.size(asiaStartBars) > 0
        drawSessionLines(asiaStartBars, asiaEndBars, asiaHighs, asiaLows, asiaHighBroken, asiaLowBroken, asiaHighBreakBar, asiaLowBreakBar, asiaColor, "Asia")

// --- London Session ---
var londonStartBars = array.new_float()
var londonEndBars   = array.new_float()
var londonHighs     = array.new_float()
var londonLows      = array.new_float()
var londonHighBroken = array.new_bool()
var londonLowBroken = array.new_bool()
var londonHighBreakBar = array.new_float()
var londonLowBreakBar = array.new_float()
if showLondon
    processSession(showLondon, londonStartH, londonStartM, londonEndH, londonEndM, londonColor, "London", 
                  londonStartBars, londonEndBars, londonHighs, londonLows, londonHighBroken, londonLowBroken, londonHighBreakBar, londonLowBreakBar)
    if array.size(londonStartBars) > 0
        drawSessionLines(londonStartBars, londonEndBars, londonHighs, londonLows, londonHighBroken, londonLowBroken, londonHighBreakBar, londonLowBreakBar, londonColor, "London")

// --- NY Session ---
var nyStartBars = array.new_float()
var nyEndBars   = array.new_float()
var nyHighs     = array.new_float()
var nyLows      = array.new_float()
var nyHighBroken = array.new_bool()
var nyLowBroken = array.new_bool()
var nyHighBreakBar = array.new_float()
var nyLowBreakBar = array.new_float()
if showNY
    processSession(showNY, nyStartH, nyStartM, nyEndH, nyEndM, nyColor, "NY", 
                  nyStartBars, nyEndBars, nyHighs, nyLows, nyHighBroken, nyLowBroken, nyHighBreakBar, nyLowBreakBar)
    if array.size(nyStartBars) > 0
        drawSessionLines(nyStartBars, nyEndBars, nyHighs, nyLows, nyHighBroken, nyLowBroken, nyHighBreakBar, nyLowBreakBar, nyColor, "NY") 