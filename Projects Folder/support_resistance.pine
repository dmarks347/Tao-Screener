//@version=5
strategy(title='Fractal based Support & Resistance V2', overlay=true)

// === Support/Resistance Settings ===
showSR = input.bool(true, title="Show Support/Resistance", group="Support/Resistance")
lookback = input.int(100, "Lookback Period", minval=10, maxval=500, group="Support/Resistance")
levelThreshold = input.float(1.0, "Level Threshold %", minval=0.1, maxval=5.0, step=0.1, group="Support/Resistance")
maxLevels = input.int(20, "Maximum Number of Levels", minval=1, maxval=20, group="Support/Resistance")
lineColor = input.color(color.white, "Line Color", group="Support/Resistance")
lineWidth = input.int(2, "Line Width", minval=1, maxval=4, group="Support/Resistance")
showLabels = input.bool(true, "Show Price Labels", group="Support/Resistance")

// === Original Inputs ===
showPatterns = input(false)
showBarColors = input(false)
filterBW = input(false, title="filter Bill Williams Fractals:")
ShowHHLL = input(false)
ShowTimeFractals1 = input(false)
timeframe1 = input.timeframe("240")

// Arrays to store fractals and their bar indices
var highFractals = array.new_float()
var highFractalBars = array.new_int()
var lowFractals = array.new_float()
var lowFractalBars = array.new_int()

// Arrays to store levels and their bar indices
var resistanceLevels = array.new_float()
var resistanceBars = array.new_int()
var supportLevels = array.new_float()
var supportBars = array.new_int()

// === Fractal Recognition Functions ===
isRegularFractal(mode) =>
    ret = mode == 1 ? high[4] < high[3] and high[3] < high[2] and high[2] > high[1] and high[1] > high[0] : mode == -1 ? low[4] > low[3] and low[3] > low[2] and low[2] < low[1] and low[1] < low[0] : false

isBWFractal(mode) =>
    ret = mode == 1 ? high[4] < high[2] and high[3] <= high[2] and high[2] >= high[1] and high[2] > high[0] : mode == -1 ? low[4] > low[2] and low[3] >= low[2] and low[2] <= low[1] and low[2] < low[0] : false

filteredtopf = filterBW ? isRegularFractal(1) : isBWFractal(1)
filteredbotf = filterBW ? isRegularFractal(-1) : isBWFractal(-1)

// Store fractals
if filteredtopf
    array.unshift(highFractals, high[2])
    array.unshift(highFractalBars, bar_index - 2)
    if array.size(highFractals) > lookback
        array.pop(highFractals)
        array.pop(highFractalBars)

if filteredbotf
    array.unshift(lowFractals, low[2])
    array.unshift(lowFractalBars, bar_index - 2)
    if array.size(lowFractals) > lookback
        array.pop(lowFractals)
        array.pop(lowFractalBars)

// Check if levels are close enough to merge
shouldMerge(level1, level2) =>
    math.abs(level1 - level2) / level1 * 100 <= levelThreshold

// Check for level formation
checkLevelFormation(fractals, fractalBars, levels, levelBars, color_) =>
    if array.size(fractals) >= 3
        for i = 0 to array.size(fractals) - 3
            price1 = array.get(fractals, i)
            for j = i + 1 to array.size(fractals) - 2
                price2 = array.get(fractals, j)
                if shouldMerge(price1, price2)
                    for k = j + 1 to array.size(fractals) - 1
                        price3 = array.get(fractals, k)
                        if shouldMerge(price2, price3)
                            avgLevel = (price1 + price2 + price3) / 3
                            array.unshift(levels, avgLevel)
                            array.unshift(levelBars, array.get(fractalBars, i))
                            if array.size(levels) > maxLevels
                                array.pop(levels)
                                array.pop(levelBars)

// Draw levels
drawLevels(levels, bars, color_) =>
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            level = array.get(levels, i)
            startBar = array.get(bars, i)
            line.new(startBar, level, bar_index, level, 
                     color=color_, width=lineWidth)
            if showLabels
                label.new(startBar, level, str.tostring(level, "#.##"), 
                         color=color.new(color_, 100), 
                         style=label.style_label_left,
                         textcolor=color_)

// Check for level formation in both high and low fractals
if showSR
    checkLevelFormation(highFractals, highFractalBars, resistanceLevels, resistanceBars, lineColor)
    checkLevelFormation(lowFractals, lowFractalBars, supportLevels, supportBars, lineColor)
    drawLevels(resistanceLevels, resistanceBars, lineColor)
    drawLevels(supportLevels, supportBars, lineColor)

// === Original Plotting ===
plotshape(filteredtopf, title='Filtered Top Fractals', style=shape.triangledown, location=location.abovebar, color=color.red, offset=-2)
plotshape(filteredbotf, title='Filtered Bottom Fractals', style=shape.triangleup, location=location.belowbar, color=color.lime, offset=-2)

// Higher Highs, Lower Highs, Higher Lows, Lower Lows
var float lastHigh = na
var float lastLow = na
var int lastHighBar = 0
var int lastLowBar = 0

if filteredtopf
    lastHigh := high[2]
    lastHighBar := bar_index - 2

if filteredbotf
    lastLow := low[2]
    lastLowBar := bar_index - 2

higherhigh = filteredtopf and not na(lastHigh) and high[2] > lastHigh
lowerhigh = filteredtopf and not na(lastHigh) and high[2] < lastHigh
higherlow = filteredbotf and not na(lastLow) and low[2] > lastLow
lowerlow = filteredbotf and not na(lastLow) and low[2] < lastLow

plotshape(ShowHHLL ? higherhigh : na, title='Higher High', style=shape.square, location=location.abovebar, color=color.maroon, text="[HH]", offset=-2)
plotshape(ShowHHLL ? lowerhigh : na, title='Lower High', style=shape.square, location=location.abovebar, color=color.maroon, text="[LH]", offset=-2)
plotshape(ShowHHLL ? higherlow : na, title='High Low', style=shape.square, location=location.belowbar, color=color.green, text="[HL]", offset=-2)
plotshape(ShowHHLL ? lowerlow : na, title='Lower Low', style=shape.square, location=location.belowbar, color=color.green, text="[LL]", offset=-2)

// Time Fractals
isTFFractal(bool mode, string tf) =>
    float tfHigh = request.security(syminfo.tickerid, tf, high, barmerge.gaps_off, barmerge.lookahead_off)
    float tfLow = request.security(syminfo.tickerid, tf, low, barmerge.gaps_off, barmerge.lookahead_off)
    bool result = mode == 1 ? 
        higherhigh and high[2] >= tfHigh : 
        (mode == -1 ? 
            lowerlow and low[2] <= tfLow : 
            false)
    result

higherhhigh = higherhigh and isTFFractal(1, timeframe1)
lowerllow = lowerlow and isTFFractal(-1, timeframe1)

plotshape(ShowTimeFractals1 ? higherhhigh : na, title='Timed Top Fractals', style=shape.square, location=location.abovebar, color=color.maroon, text="[TH]", offset=-2)
plotshape(ShowTimeFractals1 ? lowerllow : na, title='Timed Bottom Fractals', style=shape.square, location=location.belowbar, color=color.green, text="[TL]", offset=-2)

// Channels
showchannel1 = input(false)
plot(not showchannel1 ? na : (filteredtopf ? high[2] : na), title='Top Channel 1', color=color.black, offset=-2)
plot(not showchannel1 ? na : (filteredbotf ? low[2] : na), title='Bottom Channel 1', color=color.black, offset=-2)
showchannel2 = input(false)
plot(not showchannel2 ? na : (higherhigh ? high[2] : na), title='Top Channel 2', color=color.gray, offset=-2)
plot(not showchannel2 ? na : (lowerlow ? low[2] : na), title='Bottom Channel 2', color=color.gray, offset=-2)
showchannel3 = input(false)
plot(not showchannel3 ? na : (higherhhigh ? high[2] : na), title='Top Channel 3', color=color.silver, offset=-2)
plot(not showchannel3 ? na : (lowerllow ? low[2] : na), title='Bottom Channel 3', color=color.silver, offset=-2)

// ZigZag
showZigZag = input(true)
istop = ShowTimeFractals1 ? higherhhigh : filteredtopf
isbot = ShowTimeFractals1 ? lowerllow : filteredbotf
topcount = ta.barssince(istop)
botcount = ta.barssince(isbot)
zigzag = (istop and topcount[1] > botcount[1] ? high[2] : isbot and topcount[1] < botcount[1] ? low[2] : na)
plot(not showZigZag ? na : zigzag, title= 'ZigZag', color=color.white, offset=-2)

// Bar Colors
bc = zigzag and high[2] == zigzag ? color.red : zigzag and low[2] == zigzag ? color.lime : color.silver
barcolor(showBarColors ? bc : na, offset=-2)

// Pattern Recognition
var float[] zigzagValues = array.new_float(5)
if not na(zigzag)
    array.unshift(zigzagValues, zigzag)
    if array.size(zigzagValues) > 5
        array.pop(zigzagValues)

x = array.size(zigzagValues) > 4 ? array.get(zigzagValues, 4) : na
a = array.size(zigzagValues) > 3 ? array.get(zigzagValues, 3) : na
b = array.size(zigzagValues) > 2 ? array.get(zigzagValues, 2) : na
c = array.size(zigzagValues) > 1 ? array.get(zigzagValues, 1) : na
d = array.size(zigzagValues) > 0 ? array.get(zigzagValues, 0) : na

xab = not na(x) and not na(a) and not na(b) ? (math.abs(b-a)/math.abs(x-a)) : na
xad = not na(x) and not na(a) and not na(d) ? (math.abs(a-d)/math.abs(x-a)) : na
abc = not na(a) and not na(b) and not na(c) ? (math.abs(b-c)/math.abs(a-b)) : na
bcd = not na(b) and not na(c) and not na(d) ? (math.abs(c-d)/math.abs(b-c)) : na

// Pattern Functions
isBat(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 0.382 and xab <= 0.5 and
    abc >= 0.382 and abc <= 0.886 and
    bcd >= 1.618 and bcd <= 2.618 and
    xad <= 0.886 and
    (_mode == 1 ? d < c : d > c)

isAltBat(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab <= 0.382 and
    abc >= 0.382 and abc <= 0.886 and
    bcd >= 2.0 and bcd <= 3.618 and
    xad <= 1.13 and
    (_mode == 1 ? d < c : d > c)

isButterfly(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab <= 0.786 and
    abc >= 0.382 and abc <= 0.886 and
    bcd >= 1.618 and bcd <= 2.618 and
    xad >= 1.27 and xad <= 1.618 and
    (_mode == 1 ? d < c : d > c)

isABCD(_mode)=>
    not na(abc) and not na(bcd) and
    abc >= 0.382 and abc <= 0.886 and
    bcd >= 1.13 and bcd <= 2.618 and
    (_mode == 1 ? d < c : d > c)

isGartley(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 0.5 and xab <= 0.618 and
    abc >= 0.382 and abc <= 0.886 and
    bcd >= 1.13 and bcd <= 2.618 and
    xad >= 0.75 and xad <= 0.875 and
    (_mode == 1 ? d < c : d > c)

isCrab(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 0.75 and xab <= 0.875 and
    abc >= 0.382 and abc <= 0.886 and
    bcd >= 2.0 and bcd <= 3.618 and
    xad >= 1.5 and xad <= 1.625 and
    (_mode == 1 ? d < c : d > c)

isShark(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 0.5 and xab <= 0.875 and
    abc >= 1.13 and abc <= 1.618 and
    bcd >= 1.27 and bcd <= 2.24 and
    xad >= 0.88 and xad <= 1.13 and
    (_mode == 1 ? d < c : d > c)

is5o(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 1.13 and xab <= 1.618 and
    abc >= 1.618 and abc <= 2.24 and
    bcd >= 0.5 and bcd <= 0.625 and
    xad >= 0.0 and xad <= 0.236 and
    (_mode == 1 ? d < c : d > c)

isWolf(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 1.27 and xab <= 1.618 and
    abc >= 0 and abc <= 5 and
    bcd >= 1.27 and bcd <= 1.618 and
    xad >= 0.0 and xad <= 5 and
    (_mode == 1 ? d < c : d > c)

isHnS(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 2.0 and xab <= 10 and
    abc >= 0.90 and abc <= 1.1 and
    bcd >= 0.236 and bcd <= 0.88 and
    xad >= 0.90 and xad <= 1.1 and
    (_mode == 1 ? d < c : d > c)

isConTria(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 0.382 and xab <= 0.618 and
    abc >= 0.382 and abc <= 0.618 and
    bcd >= 0.382 and bcd <= 0.618 and
    xad >= 0.236 and xad <= 0.764 and
    (_mode == 1 ? d < c : d > c)

isExpTria(_mode)=>
    not na(xab) and not na(abc) and not na(bcd) and not na(xad) and
    xab >= 1.236 and xab <= 1.618 and
    abc >= 1.000 and abc <= 1.618 and
    bcd >= 1.236 and bcd <= 2.000 and
    xad >= 2.000 and xad <= 2.236 and
    (_mode == 1 ? d < c : d > c)

// Plot Patterns
plotshape(not showPatterns ? na : isABCD(-1) and not isABCD(-1)[1], text="\nAB=CD", title='Bear ABCD', style=shape.labeldown, textcolor=color.white, location=location.top, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isBat(-1) and not isBat(-1)[1], text="Bat", title='Bear Bat', style=shape.labeldown, textcolor=color.white, location=location.top, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isAltBat(-1) and not isAltBat(-1)[1], text="Alt Bat", title='Bear Alt Bat', style=shape.labeldown, textcolor=color.white, location=location.top, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isButterfly(-1) and not isButterfly(-1)[1], text="Butterfly", title='Bear Butterfly', style=shape.labeldown, textcolor=color.white, location=location.top, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isGartley(-1) and not isGartley(-1)[1], text="Gartley", title='Bear Gartley', style=shape.labeldown, textcolor=color.white, location=location.top, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isCrab(-1) and not isCrab(-1)[1], text="Crab", title='Bear Crab', style=shape.labeldown, textcolor=color.white, location=location.top, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isShark(-1) and not isShark(-1)[1], text="Shark", title='Bear Shark', style=shape.labeldown, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : is5o(-1) and not is5o(-1)[1], text="5-O", title='Bear 5-O', style=shape.labeldown, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isWolf(-1) and not isWolf(-1)[1], text="Wolf Wave", title='Bear Wolf Wave', style=shape.labeldown, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isHnS(-1) and not isHnS(-1)[1], text="Head and Shoulders", title='Bear Head and Shoulders', style=shape.labeldown, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isConTria(-1) and not isConTria(-1)[1], text="Contracting Triangle", title='Bear Contracting triangle', style=shape.labeldown, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isExpTria(-1) and not isExpTria(-1)[1], text="Expanding Triangle", title='Bear Expanding Triangle', style=shape.labeldown, color=color.new(color.maroon, 0), offset=-2)
plotshape(not showPatterns ? na : isABCD(1) and not isABCD(1)[1], text="AB=CD\n", title='Bull ABCD', style=shape.labelup, color=color.new(color.green, 0), offset=-2)
plotshape(not showPatterns ? na : isBat(1) and not isBat(1)[1], text="Bat", title='Bull Bat', style=shape.labelup, color=color.new(color.green, 0), offset=-2)
plotshape(not showPatterns ? na : isAltBat(1) and not isAltBat(1)[1], text="Alt Bat", title='Bull Alt Bat', style=shape.labelup, color=color.new(color.green, 0), offset=-2)
plotshape(not showPatterns ? na : isButterfly(1) and not isButterfly(1)[1], text="Butterfly", title='Bull Butterfly', style=shape.labelup, color=color.new(color.green, 0), offset=-2)
plotshape(not showPatterns ? na : isGartley(1) and not isGartley(1)[1], text="Gartley", title='Bull Gartley', style=shape.labelup, color=color.new(color.green, 0), offset=-2)
plotshape(not showPatterns ? na : isShark(1) and not isShark(1)[1], text="Shark", title='Bull Shark', style=shape.labelup, color=color.new(color.green, 0), offset=-2)
plotshape(not showPatterns ? na : isWolf(1) and not isWolf(1)[1], text="Wolf Wave", title='Bull Wolf Wave', style=shape.labelup, color=color.new(color.green, 0), offset=-2)
plotshape(not showPatterns ? na : isConTria(1) and not isConTria(1)[1], text="Contracting Triangle", title='Bull Contracting Triangle', style=shape.labelup, color=color.new(color.green, 0), offset=-2)
plotshape(not showPatterns ? na : isExpTria(1) and not isExpTria(1)[1], text="Expanding Triangle", title='Bull Expanding Triangle', style=shape.labelup, color=color.new(color.green, 0), offset=-2) 