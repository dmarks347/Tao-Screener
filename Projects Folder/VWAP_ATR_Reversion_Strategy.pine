//@version=6
strategy("VWAP ATR Reversion Strategy V2", overlay=true, 
         default_qty_type=strategy.fixed, 
         default_qty_value=1,
         currency=currency.USD)

// =============================================================================
// INPUT PARAMETERS
// =============================================================================

// Entry Settings
entry_hour = input.int(10, "Entry Hour (ET)", minval=6, maxval=14, step=1,
                       tooltip="Hour to enter trade (6-14 Eastern Time)", 
                       group="Entry Settings")

entry_minute = input.int(0, "Entry Minute", 
                         options=[0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55],
                         tooltip="Minute within the hour (5-minute intervals)", 
                         group="Entry Settings")

min_distance_ticks = input.int(10, "Minimum Distance from VWAP (Ticks)", 
                               minval=1, maxval=100, step=1,
                               tooltip="Minimum distance from VWAP required to enter trade", 
                               group="Entry Settings")

max_trades_per_day = input.int(1, "Maximum Trades Per Day", 
                               minval=1, maxval=10, step=1,
                               tooltip="Maximum number of trades allowed per day", 
                               group="Entry Settings")

// Risk Management
atr_length = input.int(14, "ATR Length", minval=1, maxval=50, step=1,
                       tooltip="Number of periods for ATR calculation", 
                       group="Risk Management")

atr_multiplier = input.float(1.5, "ATR Stop Loss Multiplier", minval=0.5, maxval=5.0, step=0.1,
                             tooltip="Multiplier for ATR to calculate stop loss distance", 
                             group="Risk Management")

trailing_stop_ticks = input.int(10, "Trailing Stop Distance (Ticks)", 
                                minval=1, maxval=100, step=1,
                                tooltip="Trailing stop distance when VWAP is reached", 
                                group="Risk Management")

// Exit Settings
force_close_hour = input.int(15, "Force Close Hour (ET)", minval=14, maxval=16, step=1,
                             tooltip="Hour to force close all positions", 
                             group="Exit Settings")

force_close_minute = input.int(55, "Force Close Minute", 
                               options=[0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55],
                               tooltip="Minute to force close all positions", 
                               group="Exit Settings")

// Visual Settings
show_vwap = input.bool(true, "Show VWAP Line", group="Visual")
show_signals = input.bool(true, "Show Entry/Exit Signals", group="Visual")
show_info_table = input.bool(true, "Show Info Table", group="Visual")

// =============================================================================
// CALCULATIONS
// =============================================================================

// Session VWAP (resets each day)
vwap_value = ta.vwap

// ATR calculation
atr_value = ta.atr(atr_length)

// Time checks
is_entry_time() =>
    hour(time, "America/New_York") == entry_hour and 
    minute(time, "America/New_York") == entry_minute

is_force_close_time() =>
    current_hour = hour(time, "America/New_York")
    current_minute = minute(time, "America/New_York")
    (current_hour == force_close_hour and current_minute >= force_close_minute) or
    (current_hour > force_close_hour)

// New day detection for resetting counters
is_new_day = ta.change(time("D")) != 0

// =============================================================================
// STRATEGY VARIABLES
// =============================================================================

var int trades_today = 0
var float entry_vwap = na
var float trailing_stop_level = na
var bool vwap_reached = false
var bool trailing_active = false

// Reset daily counters
if is_new_day
    trades_today := 0

// =============================================================================
// ENTRY LOGIC
// =============================================================================

// Entry conditions
can_enter = is_entry_time() and 
            trades_today < max_trades_per_day and 
            strategy.position_size == 0

if can_enter
    // Calculate distance from VWAP in ticks
    distance_ticks = math.abs(close - vwap_value) / syminfo.mintick
    
    // Check if conditions are met
    price_not_at_vwap = close != vwap_value
    meets_min_distance = distance_ticks >= min_distance_ticks
    
    if price_not_at_vwap and meets_min_distance
        // Store entry VWAP for target
        entry_vwap := vwap_value
        
        // Calculate ATR stop loss
        atr_distance = atr_value * atr_multiplier
        
        // Reset trailing variables
        vwap_reached := false
        trailing_active := false
        trailing_stop_level := na
        
        // Determine direction and enter trade
        if close > vwap_value
            // Price above VWAP -> Short (expect reversion down)
            stop_price = close + atr_distance
            strategy.entry("Short", strategy.short, qty=1)
            strategy.exit("SL", "Short", stop=stop_price)
            
            if show_signals
                label.new(bar_index, high, "SHORT\n@ " + str.tostring(close, "#.##") + 
                         "\nVWAP: " + str.tostring(vwap_value, "#.##"), 
                         color=color.red, textcolor=color.white, 
                         style=label.style_label_down, size=size.normal)
        
        else // close < vwap_value
            // Price below VWAP -> Long (expect reversion up)
            stop_price = close - atr_distance
            strategy.entry("Long", strategy.long, qty=1)
            strategy.exit("SL", "Long", stop=stop_price)
            
            if show_signals
                label.new(bar_index, high, "LONG\n@ " + str.tostring(close, "#.##") + 
                         "\nVWAP: " + str.tostring(vwap_value, "#.##"), 
                         color=color.green, textcolor=color.white, 
                         style=label.style_label_down, size=size.normal)
        
        // Increment trade counter
        trades_today := trades_today + 1

// =============================================================================
// VWAP TARGET & TRAILING STOP LOGIC
// =============================================================================

// Check if VWAP has been reached
if strategy.position_size != 0 and not vwap_reached and not na(entry_vwap)
    vwap_hit = false
    
    if strategy.position_size > 0 and close >= entry_vwap
        // Long position reached VWAP target
        vwap_hit := true
    else if strategy.position_size < 0 and close <= entry_vwap
        // Short position reached VWAP target
        vwap_hit := true
    
    if vwap_hit
        vwap_reached := true
        trailing_active := true
        
        // Cancel existing stop loss
        strategy.cancel("SL")
        
        // Set initial trailing stop
        trailing_distance = trailing_stop_ticks * syminfo.mintick
        if strategy.position_size > 0
            trailing_stop_level := close - trailing_distance
        else
            trailing_stop_level := close + trailing_distance
        
        if show_signals
            label.new(bar_index, close, "VWAP HIT!\nTrailing Active", 
                     color=color.blue, textcolor=color.white, 
                     style=label.style_label_right, size=size.small)

// Update trailing stop
if trailing_active and strategy.position_size != 0
    trailing_distance = trailing_stop_ticks * syminfo.mintick
    
    if strategy.position_size > 0
        // Long position - trail stop up
        new_stop = close - trailing_distance
        trailing_stop_level := math.max(trailing_stop_level, new_stop)
        strategy.exit("Trail", "Long", stop=trailing_stop_level)
    else
        // Short position - trail stop down  
        new_stop = close + trailing_distance
        trailing_stop_level := math.min(trailing_stop_level, new_stop)
        strategy.exit("Trail", "Short", stop=trailing_stop_level)

// =============================================================================
// FORCE CLOSE LOGIC
// =============================================================================

// Force close at specified time
if is_force_close_time() and strategy.position_size != 0
    strategy.close_all("Force Close")
    
    if show_signals and not is_force_close_time()[1]
        label.new(bar_index, close, "FORCE CLOSE\n" + 
                 str.tostring(force_close_hour) + ":" + str.tostring(force_close_minute) + " ET", 
                 color=color.orange, textcolor=color.white, 
                 style=label.style_label_left, size=size.normal)

// =============================================================================
// VISUALIZATION
// =============================================================================

// Plot VWAP
plot(show_vwap ? vwap_value : na, "VWAP", color=color.blue, linewidth=2)

// Plot trailing stop when active
plot(trailing_active ? trailing_stop_level : na, "Trailing Stop", 
     color=color.red, linewidth=2, style=plot.style_stepline)

// Highlight entry time
bgcolor(is_entry_time() ? color.new(color.yellow, 90) : na, title="Entry Time")

// Highlight VWAP reached
bgcolor(vwap_reached and not vwap_reached[1] ? color.new(color.blue, 85) : na, title="VWAP Reached")

// =============================================================================
// INFO TABLE
// =============================================================================

if show_info_table and barstate.islast
    var table info_table = table.new(position.top_right, 2, 12, bgcolor=color.white, border_width=1)
    
    // Entry time
    table.cell(info_table, 0, 0, "Entry Time", text_color=color.black, bgcolor=color.gray)
    entry_time_str = str.format("{0,number,00}:{1,number,00} ET", entry_hour, entry_minute)
    table.cell(info_table, 1, 0, entry_time_str, text_color=color.black)
    
    // Force close time
    table.cell(info_table, 0, 1, "Force Close", text_color=color.black, bgcolor=color.gray)
    close_time_str = str.format("{0,number,00}:{1,number,00} ET", force_close_hour, force_close_minute)
    table.cell(info_table, 1, 1, close_time_str, text_color=color.black)
    
    // Trades today
    table.cell(info_table, 0, 2, "Trades Today", text_color=color.black, bgcolor=color.gray)
    table.cell(info_table, 1, 2, str.tostring(trades_today) + "/" + str.tostring(max_trades_per_day), text_color=color.black)
    
    // Current position
    table.cell(info_table, 0, 3, "Position", text_color=color.black, bgcolor=color.gray)
    position_str = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "NONE"
    table.cell(info_table, 1, 3, position_str, text_color=color.black)
    
    // Current VWAP
    table.cell(info_table, 0, 4, "Current VWAP", text_color=color.black, bgcolor=color.gray)
    table.cell(info_table, 1, 4, str.tostring(vwap_value, "#.##"), text_color=color.black)
    
    // Entry VWAP target
    table.cell(info_table, 0, 5, "VWAP Target", text_color=color.black, bgcolor=color.gray)
    vwap_target_str = not na(entry_vwap) ? str.tostring(entry_vwap, "#.##") : "N/A"
    table.cell(info_table, 1, 5, vwap_target_str, text_color=color.black)
    
    // ATR value
    table.cell(info_table, 0, 6, "ATR Value", text_color=color.black, bgcolor=color.gray)
    table.cell(info_table, 1, 6, str.tostring(atr_value, "#.##"), text_color=color.black)
    
    // VWAP reached status
    table.cell(info_table, 0, 7, "VWAP Reached", text_color=color.black, bgcolor=color.gray)
    vwap_status = vwap_reached ? "YES" : "NO"
    table.cell(info_table, 1, 7, vwap_status, text_color=vwap_reached ? color.green : color.red)
    
    // Trailing active
    table.cell(info_table, 0, 8, "Trailing Active", text_color=color.black, bgcolor=color.gray)
    trailing_status = trailing_active ? "YES" : "NO"
    table.cell(info_table, 1, 8, trailing_status, text_color=trailing_active ? color.green : color.red)
    
    // Trailing stop level
    table.cell(info_table, 0, 9, "Trailing Stop", text_color=color.black, bgcolor=color.gray)
    trailing_str = trailing_active ? str.tostring(trailing_stop_level, "#.##") : "N/A"
    table.cell(info_table, 1, 9, trailing_str, text_color=color.black)
    
    // Current time
    table.cell(info_table, 0, 10, "Current Time", text_color=color.black, bgcolor=color.gray)
    current_time_str = str.format("{0,number,00}:{1,number,00} ET", hour(time, "America/New_York"), minute(time, "America/New_York"))
    table.cell(info_table, 1, 10, current_time_str, text_color=color.black)
    
    // Min distance setting
    table.cell(info_table, 0, 11, "Min Distance", text_color=color.black, bgcolor=color.gray)
    table.cell(info_table, 1, 11, str.tostring(min_distance_ticks) + " ticks", text_color=color.black)

// =============================================================================
// ALERTS
// =============================================================================

// Entry alert
if can_enter and close != vwap_value and math.abs(close - vwap_value) / syminfo.mintick >= min_distance_ticks
    direction = close > vwap_value ? "SHORT" : "LONG"
    alert_msg = "VWAP Reversion Entry: " + direction + " at " + str.tostring(close, "#.##") + 
                " | VWAP Target: " + str.tostring(vwap_value, "#.##")
    alert(alert_msg)

// VWAP reached alert
if vwap_reached and not vwap_reached[1]
    alert("VWAP Target Reached! Trailing stop activated.")

// Force close alert
if is_force_close_time() and not is_force_close_time()[1] and strategy.position_size != 0
    alert("Force close triggered at " + str.tostring(force_close_hour) + ":" + str.tostring(force_close_minute) + " ET") 