//@version=5
indicator("Elliott Wave 1-2 Detector", overlay=true)

// Input parameters
lookback = input.int(10, "Lookback Period", minval=5, maxval=50)
wave1_threshold = input.float(1.0, "Wave 1 Strength Threshold", minval=0.1, maxval=5.0, step=0.1)
wave2_retracement = input.float(0.382, "Wave 2 Minimum Retracement", minval=0.1, maxval=0.9, step=0.01)

// Function to detect Wave 1 top
isWave1Top(src) =>
    highest = ta.highest(src, lookback)
    momentum = ta.rsi(src, 14)
    isTop = src[1] < src and src > src[1] and src == highest
    strongMomentum = momentum > 70
    isTop and strongMomentum

// Function to detect Wave 2 bottom
isWave2Bottom(src, wave1High) =>
    retracement = (wave1High - src) / (wave1High - low)
    isBottom = src[1] > src and src < src[1]
    validRetracement = retracement >= wave2_retracement and retracement <= 0.618
    isBottom and validRetracement

var float wave1High = na
var bool inWave2 = false

// Wave 1 detection
if isWave1Top(close)
    wave1High := high
    inWave2 := true
    label.new(bar_index, high, "1", color=color.green, style=label.style_arrowdown, textcolor=color.white)

// Wave 2 detection
if inWave2 and isWave2Bottom(close, wave1High)
    inWave2 := false
    label.new(bar_index, low, "2", color=color.red, style=label.style_arrowup, textcolor=color.white)
    wave1High := na

// Plot arrows
plotchar(isWave1Top(close), "Wave 1 Top", "▼", location.abovebar, color.green, size=size.small)
plotchar(inWave2 and isWave2Bottom(close, wave1High), "Wave 2 Bottom", "▲", location.belowbar, color.red, size=size.small)

//@version=5
indicator("Large Price Swing Detector", overlay=true)

// User inputs
y = input.int(10, "Interval (minutes)", minval=1, maxval=60)
x = input.float(3.0, "Swing Threshold (%)", minval=0.1, maxval=20.0, step=0.1)

// Convert interval in minutes to bars (works for intraday timeframes)
interval_bars = math.round(y * 60 / timeframe.in_seconds(timeframe.period))

// Track the highest high and lowest low in the interval
delta_high = ta.highest(high, interval_bars)
delta_low = ta.lowest(low, interval_bars)

// Calculate percentage moves from lowest to highest and vice versa
up_swing = (delta_high - delta_low) / delta_low * 100

down_swing = (delta_low - delta_high) / delta_high * 100

// Detect upward swing
is_up_swing = up_swing >= x and high == delta_high
// Detect downward swing
is_down_swing = down_swing <= -x and low == delta_low

// Only mark the first swing in overlapping intervals
var float last_swing_bar = na
new_swing = na(last_swing_bar) or bar_index - last_swing_bar >= interval_bars

if is_up_swing and new_swing
    label.new(bar_index, high, "↑", color=color.white, style=label.style_arrowdown, size=size.large, textcolor=color.black)
    last_swing_bar := bar_index
if is_down_swing and new_swing
    label.new(bar_index, low, "↓", color=color.white, style=label.style_arrowup, size=size.large, textcolor=color.black)
    last_swing_bar := bar_index 